#!/bin/bash

set -euo pipefail
IFS=$'\n\t'

readonly text="$1"
readonly file=~/Pictures/background-"$RANDOM".png

resolution=$(displayplacer list | grep -E '^displayplacer ' | awk '{print $3}' | awk -F':' '{print $2}')
fontSize=$(awk -F'x' '{print $2/40}' <<< "$resolution")

gm convert \
    -size "$resolution" \
    xc:black \
    -font "/Library/Fonts/IBM-Plex-Mono/IBMPlexMono-Regular.otf" \
    -fill white \
    -density 90 \
    -pointsize "$fontSize" \
    -draw "gravity NorthWest text +$fontSize+$fontSize $text" \
    -draw "gravity North     text +0+$fontSize         $text" \
    -draw "gravity NorthEast text +$fontSize+$fontSize $text" \
    -draw "gravity West      text +$fontSize+0         $text" \
    -draw "gravity Center    text +0+0                 $text" \
    -draw "gravity East      text +$fontSize+$fontSize $text" \
    -draw "gravity SouthWest text +$fontSize+$fontSize $text" \
    -draw "gravity South     text +0+0                 $text" \
    -draw "gravity SouthEast text +$fontSize+$fontSize $text" \
  "$file"

osascript -e "tell application \"Finder\" to set desktop picture to POSIX file \"$file\""

echo Background is now set to "$file".
